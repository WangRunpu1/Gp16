[Unit]
Description=GP16 API Server
After=network.target postgresql.service redis.service

[Service]
Type=simple
User=student
WorkingDirectory=/opt/gp16/apps/api
EnvironmentFile=/opt/gp16/.env
ExecStart=/usr/bin/node dist/index.js
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
