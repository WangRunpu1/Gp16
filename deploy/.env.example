# GP16 环境变量（复制此文件为 .env 并填写真实值）
DATABASE_URL=postgresql://gp16:gp16pass@localhost/gp16
REDIS_URL=redis://127.0.0.1:6379
JWT_SECRET=change-this-to-a-random-secret
PORT=8080
REPORT_DIR=/opt/gp16/data/reports

